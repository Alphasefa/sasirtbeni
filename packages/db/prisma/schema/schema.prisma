generator client {
  provider = "prisma-client"
  output   = "../generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "sqlite"
}

model VehicleBrand {
  id        String   @id @default(cuid())
  name      String
  country   String
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  models    VehicleModel[]

  @@unique([name])
  @@map("vehicle_brand")
}

model VehicleModel {
  id        String   @id @default(cuid())
  brandId   String
  name      String
  startYear Int
  endYear   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  brand     VehicleBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  versions  VehicleVersion[]

  @@unique([brandId, name])
  @@map("vehicle_model")
}

model VehicleVersion {
  id           String   @id @default(cuid())
  modelId      String
  name         String
  engine       String
  horsepower   Int
  transmission String
  fuel         String
  price        Float
  currency     String
  country      String
  source       String
  updatedAt    DateTime @updatedAt
  model        VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  dealerStocks DealerStock[]

  @@map("vehicle_version")
}

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  String
  rate      Float
  fetchedAt DateTime @default(now())

  @@unique([currency])
  @@map("exchange_rate")
}

model Dealer {
  id        String   @id @default(cuid())
  name      String
  city      String
  address   String?
  phone     String?
  email     String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stocks    DealerStock[]

  @@map("dealer")
}

model DealerStock {
  id           String   @id @default(cuid())
  dealerId     String
  versionId    String
  price        Float
  stockStatus  String   @default("available")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  dealer       Dealer        @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  version      VehicleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  @@unique([dealerId, versionId])
  @@map("dealer_stock")
}

model Campaign {
  id          String   @id @default(cuid())
  title       String
  description String?
  discountRate Float?
  discountAmount Float?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stock       DealerStock? @relation(fields: [stockId], references: [id], onDelete: Cascade)
  stockId     String?

  @@map("campaign")
}
