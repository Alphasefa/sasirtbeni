{
  "name": "my-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "next": "^16.1.1",
      "@prisma/client": "^7.5.0",
      "@trpc/server": "^11.13.4",
      "@trpc/client": "^11.13.4",
      "better-auth": "^1.5.5",
      "effect": "^3.19.14",
      "@effect/schema": "^0.75.5",
      "@effect/vitest": "^0.28.0",
      "vitest": "^3.1.1",
      "@vitest/ui": "^3.1.1",
      "@vitest/coverage-v8": "^3.1.1",
      "jsdom": "^26.0.0",
      "@playwright/test": "^1.58.2",
      "playwright": "^1.52.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @my-app/db db:push",
    "db:studio": "turbo -F @my-app/db db:studio",
    "db:generate": "turbo -F @my-app/db db:generate",
    "db:migrate": "turbo -F @my-app/db db:migrate",
    "db:start": "turbo -F @my-app/db db:start",
    "db:watch": "turbo -F @my-app/db db:watch",
    "db:stop": "turbo -F @my-app/db db:stop",
    "db:down": "turbo -F @my-app/db db:down",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@my-app/env": "workspace:*",
    "dotenv": "^17.4.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@libsql/client": "^0.17.2",
    "@my-app/config": "workspace:*",
    "@prisma/adapter-libsql": "^7.6.0",
    "@types/node": "^22.13.14",
    "turbo": "^2.9.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
